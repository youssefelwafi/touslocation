flowchart LR
    subgraph NAV["Navigateur (VIEW)"]
        direction TB
        UI["HTML · CSS · JavaScript · jQuery"]
        CH["Highcharts.js (graphiques)"]
        DT["DataTables (tableaux)"]
        UI --> CH
        UI --> DT
    end

    subgraph SRV["Serveur — Apache 2.4 / PHP 8.1 (MVC + HMVC)"]
        direction TB
        CTRL["Contrôleurs du module KPI"]
        MODELS["Modèles (requêtes SQL paramétrées)"]
        AGG["Calcul des indicateurs + cache 5 min"]
        EXP["Exports : TCPDF (PDF) · PHPExcel (Excel)"]
        CTRL --> MODELS --> AGG
        CTRL --> EXP
    end

    DB[("MySQL 8 / MariaDB")]
    BIO["Lecteur biométrique (réseau local)"]

    NAV -->|"HTTPS · JSON · jeton de session"| CTRL
    CTRL -->|"JSON / vues HTML"| NAV
    AGG <-->|"SQL (agrégations)"| DB
    BIO -->|"événements de pointage"| DB

    classDef view fill:#e3f0ff,stroke:#0071e3,color:#0a2540;
    classDef ctrl fill:#fff4e3,stroke:#ff9500,color:#5c3b00;
    classDef db fill:#f0f0f3,stroke:#6e6e73,color:#1d1d1f;
    class UI,CH,DT view;
    class CTRL,MODELS,AGG,EXP ctrl;
    class DB,BIO db;
